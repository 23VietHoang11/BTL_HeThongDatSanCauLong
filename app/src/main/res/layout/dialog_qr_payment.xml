<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quét mã QR để thanh toán"
        android:textColor="#2E7D32"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Sử dụng App ngân hàng hoặc Momo để quét"
        android:textColor="#666666"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/imgQrCode"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginVertical="16dp"
        android:scaleType="centerCrop" />

    <Button
        android:id="@+id/btnConfirmPaid"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#2E7D32"
        android:text="Tôi đã chuyển khoản thành công"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnCancelPayment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Hủy giao dịch"
        android:textColor="#D32F2F"
        android:textStyle="bold" />
</LinearLayout>