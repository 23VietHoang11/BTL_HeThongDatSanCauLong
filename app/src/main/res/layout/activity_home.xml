<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Ảnh nền phía trên -->

        <!-- Nút Back -->
        <ImageView
            android:id="@+id/ivHeader"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@android:color/darker_gray"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteX="39dp" />

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="64dp"
            android:layout_height="55dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_circle_white"
            android:src="@drawable/ic_arrow_back"
            android:tint="#000000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="UseAppTint"
            android:contentDescription="Nút Back"/>

        <!-- Nút Đặt lịch -->
        <TextView
            android:id="@+id/btnBook"
            android:layout_width="117dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_rounded_yellow"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="Đặt lịch"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <!-- Nút Yêu thích (Heart) -->
        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="54dp"
            android:layout_height="53dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_white"
            android:src="@drawable/ic_heart"
            android:tint="#000000"
            app:layout_constraintBottom_toBottomOf="@id/btnBook"
            app:layout_constraintEnd_toStartOf="@id/btnBook"
            app:layout_constraintTop_toTopOf="@id/btnBook"
            tools:ignore="UseAppTint"
            android:contentDescription="Nút Yêu Thích"/>

        <!-- Nút Share -->
        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="51dp"
            android:layout_height="54dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_white"
            android:src="@drawable/ic_share"
            android:tint="#000000"
            app:layout_constraintBottom_toBottomOf="@id/btnFavorite"
            app:layout_constraintEnd_toStartOf="@id/btnFavorite"
            app:layout_constraintTop_toTopOf="@id/btnFavorite"
            tools:ignore="UseAppTint"
            android:contentDescription="Nút Share"/>

        <!-- Thẻ thông tin chính -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvMainInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="180dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingTop="24dp"> <!-- Padding top lớn hơn để nhường chỗ cho Badge -->

                <!-- Dòng Logo & Tên sân -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Chỗ để logo cầu lông -->
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@android:color/darker_gray" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDetailName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sân Cầu Lông Đại Học Sư Phạm"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- Tag Cầu lông -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_rounded_outline_green"
                            android:drawablePadding="4dp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="Cầu lông"
                            android:textColor="#22A676"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Đường kẻ ngang -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="#E0E0E0" />

                <!-- Địa chỉ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_location"
                        app:tint="#1B5E20" />

                    <TextView
                        android:id="@+id/tvDetailAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Nhà thi đấu ĐHSP HN 136 Xuân Thuỷ, Cầu Giấy, Hà Nội"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Thời gian -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_time"
                        app:tint="#1B5E20" />

                    <TextView
                        android:id="@+id/tvDetailTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="05:30 - 23:30"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Liên hệ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_phone"
                        app:tint="#1B5E20" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Liên hệ"
                        android:textColor="#22A676"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Badge "Chưa có đánh giá" đè lên thẻ (Phải đặt dưới CardView trong ConstraintLayout để đè lên trên) -->


        <!-- TabLayout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cvMainInfo"
            app:tabIndicatorColor="#22A676"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="#22A676"
            app:tabTextColor="#666666">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dịch vụ" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hình ảnh" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điều khoản\n&amp; quy định" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đánh giá" />
        </com.google.android.material.tabs.TabLayout>

        <View
            android:id="@+id/dividerTab"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            app:layout_constraintTop_toBottomOf="@id/tabLayout"/>

        <!-- Phần Link đặt sân -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/dividerTab">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Link đặt sân online"
                android:textColor="#E57373"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="https://datlich.alobo.vn/san/sport_cau_long_dai_hoc..."
                    android:textColor="#2E7D32"
                    android:textStyle="italic" />

                <ImageButton
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_copy"
                    android:tint="#1B5E20"
                    tools:ignore="UseAppTint"
                    android:contentDescription="Link Đặt Sân"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>