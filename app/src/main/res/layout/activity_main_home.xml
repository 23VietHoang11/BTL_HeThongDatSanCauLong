<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#C62828"
                android:paddingHorizontal="16dp"
                android:paddingTop="32dp"
                android:paddingBottom="40dp">

                <ImageView
                    android:id="@+id/ivAppLogo"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#4CAF50" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/ivAppLogo"
                    app:layout_constraintStart_toEndOf="@id/ivAppLogo"
                    app:layout_constraintTop_toTopOf="@id/ivAppLogo">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thứ tư, 11/03/2026"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phạm Đình Kiên"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivNotification"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_white"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:layout_constraintBottom_toBottomOf="@id/ivAppLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ivAppLogo"
                    app:tint="#D32F2F" />

                <ImageView
                    android:id="@+id/ivStar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_circle_transparent"
                    android:padding="6dp"
                    android:src="@android:drawable/star_on"
                    app:layout_constraintBottom_toBottomOf="@id/ivNotification"
                    app:layout_constraintEnd_toStartOf="@id/ivNotification"
                    app:layout_constraintTop_toTopOf="@id/ivNotification"
                    app:tint="#FFC107" />

            </androidx.constraintlayout.widget.ConstraintLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-24dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_bar"
                    android:elevation="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#4CAF50" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Tìm kiếm"
                        android:textColor="#9E9E9E"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#0B6A41" />
                </LinearLayout>

                <ImageButton
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search_bar"
                    android:elevation="4dp"
                    android:src="@drawable/ic_heart"
                    app:tint="#0B6A41"
                    android:contentDescription="Nút Back"/>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_map"
                    app:tint="#D32F2F" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Tìm sân trống, sự kiện xé vé, ghép đội"
                    android:textColor="#D32F2F"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="#0B6A41" />
            </LinearLayout>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">


                    <ImageView
                        android:id="@+id/ivCourt1"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@android:color/darker_gray"
                        app:layout_constraintTop_toTopOf="parent" />


                    <TextView
                        android:id="@+id/badgeDay1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_badge_green"
                        android:drawableStart="@android:drawable/star_on"
                        android:drawablePadding="4dp"
                        android:drawableTint="#FFFFFF"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="Đơn ngày"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_purple"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="Sự kiện"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@id/badgeDay1"
                        app:layout_constraintStart_toEndOf="@id/badgeDay1"
                        app:layout_constraintTop_toTopOf="@id/badgeDay1" />


                    <ImageView
                        android:id="@+id/btnShare1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_circle_white"
                        android:padding="6dp"
                        android:src="@drawable/ic_share"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#000000" />

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_circle_white"
                        android:padding="6dp"
                        android:src="@drawable/ic_heart"
                        app:layout_constraintBottom_toBottomOf="@id/btnShare1"
                        app:layout_constraintEnd_toStartOf="@id/btnShare1"
                        app:layout_constraintTop_toTopOf="@id/btnShare1"
                        app:tint="#000000" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        app:layout_constraintTop_toBottomOf="@id/ivCourt1">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:color/darker_gray" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sân Cầu Lông Đại Học Sư Phạm"
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="(357.4m) Nhà thi đấu ĐHSP HN 136 Xuân Thuỷ, Cầu Giấy..."
                                android:textColor="#666666"
                                android:textSize="12sp"
                                android:maxLines="1"
                                android:ellipsize="end"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:drawableStart="@drawable/ic_time"
                                android:drawablePadding="4dp"
                                android:drawableTint="#666666"
                                android:text="05:30 - 23:30"
                                android:textColor="#666666"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnBookHome1"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_gravity="center_vertical"
                            android:background="@drawable/bg_btn_yellow"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="ĐẶT LỊCH"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ivCourt2"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@android:color/darker_gray"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/badgeDay2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="36dp"
                        android:background="@drawable/bg_badge_green"
                        android:drawableStart="@android:drawable/star_on"
                        android:drawablePadding="4dp"
                        android:drawableTint="#FFFFFF"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="Đơn ngày"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_purple"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="Sự kiện"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@id/badgeDay2"
                        app:layout_constraintStart_toEndOf="@id/badgeDay2"
                        app:layout_constraintTop_toTopOf="@id/badgeDay2" />

                    <ImageView
                        android:id="@+id/btnShare2"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_circle_white"
                        android:padding="6dp"
                        android:src="@drawable/ic_share"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#000000" />

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_circle_white"
                        android:padding="6dp"
                        android:src="@drawable/ic_heart"
                        app:layout_constraintBottom_toBottomOf="@id/btnShare2"
                        app:layout_constraintEnd_toStartOf="@id/btnShare2"
                        app:layout_constraintTop_toTopOf="@id/btnShare2"
                        app:tint="#000000" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        app:layout_constraintTop_toBottomOf="@id/ivCourt2">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:color/darker_gray" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="XUÂN THỦY"
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="(358.0m) Số 2 Ngõ 181 Xuân Thuỷ, Cầu Giấy..."
                                android:textColor="#666666"
                                android:textSize="12sp"
                                android:maxLines="1"
                                android:ellipsize="end"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:drawableStart="@drawable/ic_time"
                                android:drawablePadding="4dp"
                                android:drawableTint="#666666"
                                android:text="06:00 - 22:30"
                                android:textColor="#666666"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_gravity="center_vertical"
                            android:background="@drawable/bg_btn_gray"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="ĐẶT LỊCH"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>


    <LinearLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#4CAF50"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trang chủ" android:textColor="#4CAF50" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_map" app:tint="#9E9E9E"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bản đồ" android:textColor="#9E9E9E" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>


        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_marginTop="-20dp">
            <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_circle_white" android:padding="8dp" android:src="@android:drawable/ic_menu_view" app:tint="#4CAF50" android:elevation="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Khám phá" android:textColor="#9E9E9E" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navFeatured" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_whatshot"
                app:tint="#9E9E9E" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nổi bật" android:textColor="#9E9E9E" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navAccount" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#9E9E9E"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tài khoản" android:textColor="#9E9E9E" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>